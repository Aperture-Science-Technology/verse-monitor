{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(git *)",
      "Bash(docker *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(pytest *)",
      "Bash(ruff *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(uw *)",
      "Bash(iptables *)",
      "Bash(sshd *)",
      "Read(.env)",
      "Read(**/.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m py_compile $CLAUDE_FILE_PATHS 2>&1 || true"
          }
        ]
      }
    ]
  }
}

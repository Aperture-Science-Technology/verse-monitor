# ============================================================
# verse-monitor — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git (it's in .gitignore).
# ============================================================

# --- Redis ---
REDIS_URL=redis://redis-verse:6379
REDIS_PASSWORD=change-me

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sc_events

# --- OpenRouter / Embeddings ---
OPENROUTER_API_KEY=sk-...
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1

# --- Wiki API ---
WIKI_API_BASE=https://api.star-citizen.wiki/api

# --- Discord Webhooks (optional) ---
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_HIGH=
DISCORD_WEBHOOK_MEDIUM=

# --- Ingestion ---
INGESTION_INTERVAL=86400

# --- Polling Intervals (seconds) ---
POLL_ROADMAP_INTERVAL=300
POLL_DEVTRACKER_INTERVAL=120
POLL_COMMLINKS_INTERVAL=300
POLL_REDDIT_INTERVAL=180

# --- Redis Stream ---
STREAM_NAME=sc:events
STREAM_MAXLEN=2000
DEDUP_TTL=86400

# --- Consumer Group ---
CONSUMER_GROUP=alert-workers
CONSUMER_NAME=worker-1

# --- HTTP ---
HTTP_TIMEOUT=30
HTTP_RETRIES=2
HTTP_RETRY_BACKOFF=5

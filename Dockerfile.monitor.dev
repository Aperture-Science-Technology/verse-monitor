FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libxml2-dev libxslt-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir -e .

# Install watchdog for file watching (hot-reload)
RUN pip install --no-cache-dir watchdog

ENV PYTHONPATH=/app

# Hot-reload: mount source code as volume in docker-compose.dev.yml
# Use watchdog to restart on file changes
CMD ["python3", "-m", "verse_monitor.main"]

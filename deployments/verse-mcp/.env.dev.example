# ============================================================
# verse-mcp/.env.dev.example — Environnement de développement
# ============================================================
# Copier vers .env.dev et remplir les valeurs
# NE PAS commiter .env.dev (contient des secrets)
# ============================================================

# Redis dev — mot de passe différent de prod
REDIS_PASSWORD_DEV=CHANGE_ME

# Qdrant dev — clé API différente de prod
QDRANT_API_KEY_DEV=CHANGE_ME

# OpenRouter — même clé que prod (API partagée)
OPENROUTER_API_KEY=CHANGE_ME

# Portal dev — admin API key
ADMIN_API_KEY_DEV=CHANGE_ME

# Discord webhooks — mêmes que prod (ou désactiver en dev)
DISCORD_WEBHOOK_CRITICAL=CHANGE_ME
DISCORD_WEBHOOK_HIGH=CHANGE_ME
DISCORD_WEBHOOK_MEDIUM=CHANGE_ME

# Intervals — plus rapides en dev pour tester
POLL_ROADMAP_INTERVAL=30
POLL_DEVTRACKER_INTERVAL=30
POLL_COMMLINKS_INTERVAL=30

# ============================================================
# verse-mcp/.env.dev.example — Environnement de développement
# ============================================================
# Copier vers .env.dev et remplacer les valeurs
# NE PAS commiter .env.dev (contient des secrets même en dev)
# Données mockées / échantillons — PAS DE DONNÉES DE PROD
# ============================================================

# Redis dev — mot de passe simple, pas de persistance
REDIS_PASSWORD_DEV=*** Redis URL complète (utilisée par docker-compose)
REDIS_URL=redis://:dev@redis-verse-dev:6379

# Qdrant dev — clé API factice, instance vide pour tests
QDRANT_API_KEY_DEV=*** Qdrant URL
QDRANT_URL=http://qdrant-dev:6333

# OpenRouter — mock key (pas de vrais appels LLM en dev)
OPENROUTER_API_KEY=*** Portal dev — admin API key
ADMIN_API_KEY_DEV=*** Discord webhooks — DÉSACTIVÉ en dev (laisser vide)
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_HIGH=
DISCORD_WEBHOOK_MEDIUM=

# Mode mock — les services utilisent des données échantillons
MOCK_DATA=true
DEV_MODE=true

# Intervals — plus rapides en dev pour tester
POLL_ROADMAP_INTERVAL=30
POLL_DEVTRACKER_INTERVAL=30
POLL_COMMLINKS_INTERVAL=30

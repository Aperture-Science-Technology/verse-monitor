FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (layer caching)
COPY pyproject.toml .
RUN pip install --no-cache-dir -e .

# Install watchdog for file watching (hot-reload)
RUN pip install --no-cache-dir watchdog

# Non-root user
RUN useradd --create-home appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

ENV PYTHONPATH=/app
ENV PORT=8000

# Hot-reload: mount source code as volume in docker-compose.dev.yml
# Use uvicorn --reload for auto-restart on file changes
CMD ["python3", "-m", "verse_mcp.server"]

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libxml2-dev libxslt-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir -e .

ENV PYTHONPATH=/app
ENV PORT=8080

EXPOSE 8080

# Hot-reload: mount source code as volume in docker-compose.dev.yml
CMD ["uvicorn", "verse_monitor.webhook_portal.api:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]
